{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://heimeliq.de/schema/heimeliq.schema.json",
  "title": "heimeliQ Manifest",
  "description": "Projektspezifische Erweiterungen, die das OKH-Manifest ergänzen.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "heimeliq-template-version",
    "heimeliq-instruction-version",
    "version",
    "slug",
    "series",
    "type",
    "status",
    "forest",
    "assemblies"
  ],
  "properties": {
    "heimeliq-template-version": {
      "description": "SemVer-Version der heimeliQ-Vorlage, auf der dieses Repo basiert.",
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "version": {
      "description": "SemVer-Version dieses Möbels.",
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "slug": {
      "description": "URL-Slug, identisch mit dem Repo-Namen ohne 'heimeliq-' Präfix. Schema: <reihe>-<waldname>.",
      "type": "string",
      "pattern": "^(massiq|workaholiq|keiliq)-[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "series": {
      "description": "Reihe, zu der dieses Möbel gehört.",
      "type": "string",
      "enum": ["massiq", "workaholiq", "keiliq"]
    },
    "type": {
      "description": "Möbel-Typ als Metadatenfeld für Filter/Suche. Kein Teil der ID.",
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "tags": {
      "description": "Weitere Schlagworte für Filter und Suche.",
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*$"
      },
      "uniqueItems": true
    },
    "status": {
      "description": "Veröffentlichungsstatus.",
      "type": "string",
      "enum": ["draft", "published", "archived"]
    },
    "forest": {
      "description": "Wald-Namensgeber dieses Möbels.",
      "type": "object",
      "required": ["id", "name", "region", "country"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "name": { "type": "string", "minLength": 2 },
        "region": { "type": "string" },
        "country": {
          "type": "string",
          "pattern": "^[A-Z]{2}$"
        },
        "forest_type": { "type": "string" },
        "age_estimate_years": {
          "type": "integer",
          "minimum": 0
        },
        "status": {
          "type": "string",
          "enum": ["protected", "partially-protected", "endangered", "critically-endangered", "stable", "unknown"]
        },
        "themes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "links": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label", "url"],
            "properties": {
              "label": { "type": "string" },
              "url": { "type": "string", "format": "uri" }
            }
          }
        },
        "note": { "type": "string" }
      }
    },
    "assemblies": {
      "description": "Baugruppen des Möbels. Mindestens die Hauptbaugruppe A001 (= das Möbel selbst) ist Pflicht. Sub-Baugruppen referenzieren ihre Eltern-Baugruppe über 'parent'.",
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["heimeliq-assembly-id", "name"],
        "properties": {
          "heimeliq-assembly-id": {
            "description": "Möbel-lokale Assembly-ID, z. B. 'A001' (Hauptbaugruppe), 'A002', ...",
            "type": "string",
            "pattern": "^A[0-9]{3}$"
          },
          "name": { "type": "string", "minLength": 2 },
          "description": { "type": "string" },
          "source": {
            "description": "Pfad zur FreeCAD-Quelldatei der Baugruppe, z. B. 'cad/source/A001-Sideboard.FCStd'.",
            "type": "string"
          },
          "parent": {
            "description": "Eltern-Baugruppe (nur bei Sub-Baugruppen). Muss eine existierende heimeliq-assembly-id sein.",
            "type": "string",
            "pattern": "^A[0-9]{3}$"
          },
          "optional": {
            "description": "Ist diese Baugruppe optional (Erweiterung)? Default: false (= Teil des Grundmodells).",
            "type": "boolean",
            "default": false
          }
        }
      }
    },
    "external_parts": {
      "description": "Externe Drittteile (nicht open source). Jede ID muss mit einem Assembly-Präfix beginnen (z. B. A001.E001).",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["heimeliq-part-id", "name", "quantity"],
        "properties": {
          "heimeliq-part-id": {
            "description": "Assembly-präfixierte ID, z. B. 'A001.E001' oder 'A002.E001'. Tieferes Nesting möglich: 'A002.A003.E001'.",
            "type": "string",
            "pattern": "^(A[0-9]{3}\\.)+E[0-9]{3}$"
          },
          "name": { "type": "string" },
          "standard": { "type": "string" },
          "material": { "type": "string" },
          "dimensions": { "type": "string" },
          "manufacturer": { "type": "string" },
          "manufacturer_article_number": { "type": "string" },
          "quantity": {
            "type": "integer",
            "minimum": 1
          },
          "suppliers": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "wood_options": {
      "description": "Holzarten, in denen das Möbel konstruktiv möglich ist.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["species"],
        "properties": {
          "species": { "type": "string" },
          "origin": { "type": "string" },
          "recommended": { "type": "boolean" }
        }
      }
    },
    "care": {
      "type": "object",
      "properties": {
        "surface_treatment": { "type": "string" },
        "recommended_products": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "sustainability": {
      "type": "object",
      "properties": {
        "wood_source": { "type": "string" },
        "co2_documented": { "type": "boolean" }
      }
    }
  }
}
